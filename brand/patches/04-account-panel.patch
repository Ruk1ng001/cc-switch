@@ -0,0 +1,221 @@
+// [ccs] 账户面板里的单个 key 卡片。
+//
+// cc-switch 里「一个 new-api key」= 一条 providerType:"newapi" 的 UniversalProvider。
+// 本卡片拿单条渠道的 {baseUrl, apiKey} 调 useAccountProfile 拉 profile，展示：
+//   - key 打码 + 展示名（本地 name 优先，空则用远端 token.Name）；
+//   - 账户余额 / 今日用量 / 当前 key 额度（unlimited 时显示「额度不限」）；
+//   - 状态徽标（禁用/过期/耗尽）、过期告警、动态倍率；
+//   - 「重新铺开到 Claude/Codex/Gemini」按钮（走一键导入，见补丁 05）。
+//
+// 换算/打码/使用率全走 03 的 format.ts 纯函数（与 open-code 同源）。key 明文绝不整段渲染。
+
+import { RefreshCw, Trash2 } from "lucide-react";
+import { useTranslation } from "react-i18next";
+import { Card, CardContent } from "@/components/ui/card";
+import { Badge } from "@/components/ui/badge";
+import { Button } from "@/components/ui/button";
+import { ProviderIcon } from "@/components/ProviderIcon";
+import type { UniversalProvider } from "@/types";
+import { useAccountProfile } from "./useAccountProfile";
+import {
+  formatCurrency,
+  formatTokenCount,
+  maskKey,
+  keyUsedPercent,
+  formatExpiry,
+  keyStatusLabel,
+} from "@/lib/account/format";
+
+interface KeyCardProps {
+  provider: UniversalProvider;
+  // 重新铺开到各 CLI（补丁 05 接线）。可选：未接线时按钮不渲染。
+  onImport?: (provider: UniversalProvider) => void;
+  importing?: boolean;
+  // [ccs] 删除该渠道（含二次确认，见 AccountPanel.handleDelete）。可选：未接线时按钮不渲染。
+  onDelete?: (provider: UniversalProvider) => void;
+  deleting?: boolean;
+}
+
+export function KeyCard({
+  provider,
+  onImport,
+  importing,
+  onDelete,
+  deleting,
+}: KeyCardProps) {
+  const { t } = useTranslation();
+  const { data, isFetching, isError, refetch } = useAccountProfile({
+    keyId: provider.id,
+    baseUrl: provider.baseUrl,
+    apiKey: provider.apiKey,
+  });
+
+  const profile = data?.ok ? data.profile : undefined;
+  // 展示名：本地 name 优先，空则用远端 token.Name，再空用占位。
+  const displayName =
+    provider.name.trim() ||
+    profile?.tokenName.trim() ||
+    t("account.unnamedKey", { defaultValue: "未命名 key" });
+
+  const errorText =
+    (data && !data.ok ? data.error : undefined) ??
+    (isError
+      ? t("account.loadError", { defaultValue: "加载失败，稍后重试" })
+      : undefined);
+
+  const expiry = profile ? formatExpiry(profile.keyExpiresAt) : null;
+  const statusLabel = profile ? keyStatusLabel(profile.keyStatus) : "";
+
+  return (
+    <Card>
+      <CardContent className="p-4 space-y-3">
+        {/* 头部：图标 + 名称 + 打码 key + 徽标 + 刷新 */}
+        <div className="flex items-start justify-between gap-3">
+          <div className="flex items-center gap-3 min-w-0">
+            <ProviderIcon
+              icon={provider.icon}
+              name={provider.name}
+              size={28}
+            />
+            <div className="min-w-0">
+              <div className="flex items-center gap-2">
+                <span className="font-medium truncate">{displayName}</span>
+                {statusLabel && (
+                  <Badge variant="destructive">{statusLabel}</Badge>
+                )}
+                {profile?.keyDynamicRatio && (
+                  <Badge variant="secondary">
+                    {t("account.dynamicRatio", { defaultValue: "动态倍率" })}
+                  </Badge>
+                )}
+                {expiry && expiry.level !== "ok" && (
+                  <Badge
+                    variant={
+                      expiry.level === "expired" ? "destructive" : "secondary"
+                    }
+                  >
+                    {expiry.text}
+                  </Badge>
+                )}
+              </div>
+              <span className="text-xs text-muted-foreground font-mono">
+                {maskKey(provider.apiKey)}
+              </span>
+            </div>
+          </div>
+          <div className="flex items-center gap-1 flex-shrink-0">
+            <Button
+              variant="ghost"
+              size="icon"
+              onClick={() => refetch()}
+              title={t("account.refresh", { defaultValue: "刷新" })}
+              disabled={isFetching}
+            >
+              <RefreshCw
+                className={`w-4 h-4 ${isFetching ? "animate-spin" : ""}`}
+              />
+            </Button>
+            {/* [ccs] 删除该渠道（含二次确认，见 AccountPanel.handleDelete）。 */}
+            {onDelete && (
+              <Button
+                variant="ghost"
+                size="icon"
+                onClick={() => onDelete(provider)}
+                title={t("common.delete", { defaultValue: "删除" })}
+                disabled={deleting}
+                className="text-destructive hover:text-destructive hover:bg-destructive/10"
+              >
+                <Trash2 className="w-4 h-4" />
+              </Button>
+            )}
+          </div>
+        </div>
+
+        {/* 错误态 */}
+        {errorText && (
+          <div className="text-xs text-destructive">{errorText}</div>
+        )}
+
+        {/* 就绪态：key 级用量指标（账户级余额/今日用量在面板顶部概览展示，此处不重复）。 */}
+        {profile && (
+          <div className="grid grid-cols-2 gap-3 sm:grid-cols-4">
+            <Metric
+              label={t("account.keyTokensToday", {
+                defaultValue: "今日 Tokens",
+              })}
+              value={formatTokenCount(profile.keyTokensUsedToday)}
+            />
+            <Metric
+              label={t("account.keyCostToday", { defaultValue: "今日费用" })}
+              value={
+                profile.keyQuotaUsedToday == null
+                  ? "—"
+                  : formatCurrency(profile.keyQuotaUsedToday)
+              }
+            />
+            <Metric
+              label={t("account.keyCostTotal", { defaultValue: "累计费用" })}
+              value={formatCurrency(profile.keyUsedQuota)}
+            />
+            <Metric
+              label={t("account.keyQuota", { defaultValue: "Key 额度" })}
+              value={
+                profile.keyUnlimitedQuota
+                  ? t("account.unlimited", { defaultValue: "不限" })
+                  : formatCurrency(profile.keyRemainingQuota)
+              }
+            />
+          </div>
+        )}
+
+        {/* key 额度使用率条（unlimited 不展示；用 key 级已用/剩余换算）。 */}
+        {profile && !profile.keyUnlimitedQuota && (
+          <UsageBar
+            percent={keyUsedPercent(
+              profile.keyUsedQuota,
+              profile.keyRemainingQuota,
+            )}
+          />
+        )}
+
+        {/* 重新铺开按钮 */}
+        {onImport && (
+          <div className="flex justify-end">
+            <Button
+              variant="outline"
+              size="sm"
+              onClick={() => onImport(provider)}
+              disabled={importing}
+            >
+              {importing
+                ? t("account.importing", { defaultValue: "铺开中…" })
+                : t("account.importToClis", {
+                    defaultValue: "重新铺开到各 CLI",
+                  })}
+            </Button>
+          </div>
+        )}
+      </CardContent>
+    </Card>
+  );
+}
+
+function Metric({ label, value }: { label: string; value: string }) {
+  return (
+    <div className="space-y-0.5">
+      <div className="text-xs text-muted-foreground">{label}</div>
+      <div className="text-sm font-semibold tabular-nums">{value}</div>
+    </div>
+  );
+}
+
+function UsageBar({ percent }: { percent: number }) {
+  return (
+    <div className="h-1.5 w-full rounded-full bg-muted overflow-hidden">
+      <div
+        className="h-full rounded-full bg-blue-500 transition-all"
+        style={{ width: `${percent}%` }}
+      />
+    </div>
+  );
+}
diff --git a/src/components/account/importKey.ts b/src/components/account/importKey.ts
new file mode 100644
index 00000000..2818b452
--- /dev/null
+++ b/src/components/account/importKey.ts
@@ -0,0 +1,66 @@
+// [ccs] 一键导入 / 铺开逻辑。
+//
+// cc-switch 里「一个 new-api key」= 一条 providerType:"newapi" 的 UniversalProvider，
+// upsert 后 sync 会把该 {baseUrl, apiKey} + 预设模型一次性写进 Claude / Codex / Gemini 三个 CLI。
+// 这里封装两条路径：
+//   - bindAccount：账户面板表单「绑定新账户」——用 NewAPI 预设新建一条渠道，upsert + sync；
+//   - reapplyProvider：KeyCard「重新铺开到各 CLI」——已有渠道重新 sync（凭据/模型没变，仅重写 CLI 配置）。
+//
+// 与 open-code 对齐：open-code 那边「激活 key」= 把选中 key 写进各 CLI 的 env；这里等价动作是
+// upsert + sync（sync 即 cc-switch 的落盘到各应用配置）。
+
+import { universalProvidersApi } from "@/lib/api";
+import {
+  createUniversalProviderFromPreset,
+  findPresetByType,
+} from "@/config/universalProviderPresets";
+import { generateUUID } from "@/utils/uuid";
+import type { UniversalProvider } from "@/types";
+
+// [ccs] 规整 baseUrl：去掉尾部斜杠。后端 derive_api_base 会再做 /api/... 拼接，这里只做表层清理。
+function normalizeBaseUrl(raw: string): string {
+  return raw.trim().replace(/\/+$/, "");
+}
+
+export interface BindAccountArgs {
+  baseUrl: string;
+  apiKey: string;
+  // 展示名。留空则回落到预设名 "NewAPI"（远端 token.Name 由卡片按需覆盖展示）。
+  name?: string;
+}
+
+// [ccs] 绑定新账户：用 NewAPI 预设组装一条 newapi 渠道并落盘到各 CLI。返回新建的渠道。
+// 失败（找不到预设 / upsert 失败）抛错，由调用方（AccountPanel）捕获展示。
+export async function bindAccount({
+  baseUrl,
+  apiKey,
+  name,
+}: BindAccountArgs): Promise<UniversalProvider> {
+  const preset = findPresetByType("newapi");
+  if (!preset) {
+    throw new Error("缺少 NewAPI 预设，无法绑定账户");
+  }
+
+  const provider = createUniversalProviderFromPreset(
+    preset,
+    generateUUID(),
+    normalizeBaseUrl(baseUrl),
+    apiKey.trim(),
+    name?.trim() || undefined,
+  );
+
+  const ok = await universalProvidersApi.upsert(provider);
+  if (!ok) {
+    throw new Error("保存渠道失败");
+  }
+  // 铺开到 Claude / Codex / Gemini。sync 失败不影响渠道已存在，交由调用方决定是否提示。
+  await universalProvidersApi.sync(provider.id);
+  return provider;
+}
+
+// [ccs] 重新铺开已有渠道到各 CLI：凭据/模型未变，仅重写 CLI 配置（等价 open-code 的重新激活）。
+export async function reapplyProvider(
+  provider: UniversalProvider,
+): Promise<void> {
+  await universalProvidersApi.sync(provider.id);
+}
