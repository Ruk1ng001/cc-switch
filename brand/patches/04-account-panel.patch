diff --git a/src/components/account/AccountPanel.tsx b/src/components/account/AccountPanel.tsx
new file mode 100644
index 00000000..d3b2eda7
--- /dev/null
+++ b/src/components/account/AccountPanel.tsx
@@ -0,0 +1,219 @@
+// [ccs] 账户面板容器。
+//
+// 列出所有 providerType:"newapi" 的 UniversalProvider（= 一个个 new-api key），逐个渲染 KeyCard
+// 展示余额/用量/key 元数据；并提供「绑定新账户」表单（复用 importKey.ts 的 bindAccount 组装
+// 一条 newapi 渠道 + 铺开到各 CLI）。KeyCard 的「重新铺开」走 reapplyProvider。
+//
+// 与 open-code 的账户体系对齐：那边是「账户 → 多 key → 激活写入各 CLI」；cc-switch 里没有独立的
+// 账户实体，一条 newapi 渠道即一个 key，绑定/激活统一落到 UniversalProvider 的 upsert + sync。
+// 渠道列表用 cc-switch 现成的 universalProvidersApi（settings KV 落盘），本层不新增任何存储。
+
+import { useCallback, useEffect, useState } from "react";
+import { useTranslation } from "react-i18next";
+import { UserPlus, RefreshCw } from "lucide-react";
+import { toast } from "sonner";
+import { Card, CardContent } from "@/components/ui/card";
+import { Button } from "@/components/ui/button";
+import { Input } from "@/components/ui/input";
+import { Label } from "@/components/ui/label";
+import { universalProvidersApi } from "@/lib/api";
+import type { UniversalProvider, UniversalProvidersMap } from "@/types";
+import { KeyCard } from "./KeyCard";
+import { bindAccount, reapplyProvider } from "./importKey";
+
+// [ccs] 内置 new-api 站点根：写死为本项目自建网关，用户绑定时无需（也无法）填接口地址。
+// 该值会同时用于 (1) 铺开到各 CLI 的 ANTHROPIC_BASE_URL（原样写入，new-api 在站点根挂
+// Anthropic 兼容端点）；(2) 查余额（后端 derive_api_base 从此推导 /api/app/profile）。
+// 换网关只改这一处常量即可。
+export const BUILTIN_NEWAPI_BASE_URL = "https://dokng.com";
+
+export function AccountPanel() {
+  const { t } = useTranslation();
+
+  const [providers, setProviders] = useState<UniversalProvidersMap>({});
+  const [loading, setLoading] = useState(true);
+  // 正在「重新铺开」的渠道 id（禁用对应卡片按钮）。
+  const [reapplyingId, setReapplyingId] = useState<string | null>(null);
+
+  // 绑定表单（接口地址内置为 BUILTIN_NEWAPI_BASE_URL，不暴露给用户）
+  const [apiKey, setApiKey] = useState("");
+  const [name, setName] = useState("");
+  const [binding, setBinding] = useState(false);
+
+  const load = useCallback(async () => {
+    try {
+      setLoading(true);
+      const data = await universalProvidersApi.getAll();
+      setProviders(data);
+    } catch (error) {
+      console.error("Failed to load providers:", error);
+      toast.error(
+        t("account.loadListError", { defaultValue: "加载账户列表失败" }),
+      );
+    } finally {
+      setLoading(false);
+    }
+  }, [t]);
+
+  useEffect(() => {
+    load();
+  }, [load]);
+
+  // 只展示 newapi 渠道（一条 = 一个 new-api key）。按 sortIndex → createdAt 稳定排序。
+  const newapiProviders = Object.values(providers)
+    .filter((p) => p.providerType === "newapi")
+    .sort((a, b) => {
+      const si = (a.sortIndex ?? 0) - (b.sortIndex ?? 0);
+      if (si !== 0) return si;
+      return (a.createdAt ?? 0) - (b.createdAt ?? 0);
+    });
+
+  const handleBind = useCallback(async () => {
+    if (!apiKey.trim()) {
+      toast.error(
+        t("account.bindMissing", {
+          defaultValue: "请填写 API Key",
+        }),
+      );
+      return;
+    }
+    try {
+      setBinding(true);
+      // [ccs] 接口地址内置，不由用户填写。
+      await bindAccount({ baseUrl: BUILTIN_NEWAPI_BASE_URL, apiKey, name });
+      toast.success(
+        t("account.bindSuccess", { defaultValue: "已绑定并铺开到各 CLI" }),
+      );
+      setApiKey("");
+      setName("");
+      await load();
+    } catch (error) {
+      const message = error instanceof Error ? error.message : String(error);
+      toast.error(
+        t("account.bindError", {
+          defaultValue: "绑定失败：{{error}}",
+          error: message,
+        }),
+      );
+    } finally {
+      setBinding(false);
+    }
+  }, [apiKey, name, load, t]);
+
+  const handleReapply = useCallback(
+    async (provider: UniversalProvider) => {
+      try {
+        setReapplyingId(provider.id);
+        await reapplyProvider(provider);
+        toast.success(
+          t("account.reapplySuccess", { defaultValue: "已重新铺开到各 CLI" }),
+        );
+      } catch (error) {
+        const message = error instanceof Error ? error.message : String(error);
+        toast.error(
+          t("account.reapplyError", {
+            defaultValue: "铺开失败：{{error}}",
+            error: message,
+          }),
+        );
+      } finally {
+        setReapplyingId(null);
+      }
+    },
+    [t],
+  );
+
+  return (
+    <div className="space-y-4">
+      {/* 绑定新账户表单 */}
+      <Card>
+        <CardContent className="p-4 space-y-3">
+          <div className="flex items-center gap-2">
+            <UserPlus className="w-4 h-4 text-muted-foreground" />
+            <span className="font-medium">
+              {t("account.bindTitle", { defaultValue: "绑定新账户" })}
+            </span>
+          </div>
+          <div className="grid gap-3 sm:grid-cols-2">
+            <div className="space-y-1 sm:col-span-2">
+              <Label htmlFor="ccs-account-name">
+                {t("account.displayName", { defaultValue: "展示名（可选）" })}
+              </Label>
+              <Input
+                id="ccs-account-name"
+                value={name}
+                onChange={(e) => setName(e.target.value)}
+                placeholder={t("account.namePlaceholder", {
+                  defaultValue: "留空用远端名称",
+                })}
+                disabled={binding}
+              />
+            </div>
+            <div className="space-y-1 sm:col-span-2">
+              <Label htmlFor="ccs-account-key">
+                {t("account.apiKey", { defaultValue: "API Key" })}
+              </Label>
+              <Input
+                id="ccs-account-key"
+                type="password"
+                value={apiKey}
+                onChange={(e) => setApiKey(e.target.value)}
+                placeholder="sk-..."
+                disabled={binding}
+              />
+            </div>
+          </div>
+          <div className="flex justify-end">
+            <Button onClick={handleBind} disabled={binding}>
+              {binding
+                ? t("account.binding", { defaultValue: "绑定中…" })
+                : t("account.bind", { defaultValue: "绑定并铺开" })}
+            </Button>
+          </div>
+        </CardContent>
+      </Card>
+
+      {/* 已绑定的 key 列表 */}
+      <div className="flex items-center justify-between">
+        <span className="text-sm text-muted-foreground">
+          {t("account.listTitle", {
+            defaultValue: "已绑定账户",
+          })}
+          {newapiProviders.length > 0 ? ` (${newapiProviders.length})` : ""}
+        </span>
+        <Button
+          variant="ghost"
+          size="icon"
+          onClick={load}
+          disabled={loading}
+          title={t("account.reloadList", { defaultValue: "刷新列表" })}
+        >
+          <RefreshCw className={`w-4 h-4 ${loading ? "animate-spin" : ""}`} />
+        </Button>
+      </div>
+
+      {loading ? (
+        <div className="text-sm text-muted-foreground py-8 text-center">
+          {t("account.loading", { defaultValue: "加载中…" })}
+        </div>
+      ) : newapiProviders.length === 0 ? (
+        <div className="text-sm text-muted-foreground py-8 text-center">
+          {t("account.empty", {
+            defaultValue: "还没有绑定任何账户，用上方表单绑定第一个",
+          })}
+        </div>
+      ) : (
+        <div className="grid gap-3 sm:grid-cols-2">
+          {newapiProviders.map((provider) => (
+            <KeyCard
+              key={provider.id}
+              provider={provider}
+              onImport={handleReapply}
+              importing={reapplyingId === provider.id}
+            />
+          ))}
+        </div>
+      )}
+    </div>
+  );
+}
diff --git a/src/components/account/KeyCard.tsx b/src/components/account/KeyCard.tsx
new file mode 100644
index 00000000..8f363c52
--- /dev/null
+++ b/src/components/account/KeyCard.tsx
@@ -0,0 +1,203 @@
+// [ccs] 账户面板里的单个 key 卡片。
+//
+// cc-switch 里「一个 new-api key」= 一条 providerType:"newapi" 的 UniversalProvider。
+// 本卡片拿单条渠道的 {baseUrl, apiKey} 调 useAccountProfile 拉 profile，展示：
+//   - key 打码 + 展示名（本地 name 优先，空则用远端 token.Name）；
+//   - 账户余额 / 今日用量 / 当前 key 额度（unlimited 时显示「额度不限」）；
+//   - 状态徽标（禁用/过期/耗尽）、过期告警、动态倍率；
+//   - 「重新铺开到 Claude/Codex/Gemini」按钮（走一键导入，见补丁 05）。
+//
+// 换算/打码/使用率全走 03 的 format.ts 纯函数（与 open-code 同源）。key 明文绝不整段渲染。
+
+import { RefreshCw } from "lucide-react";
+import { useTranslation } from "react-i18next";
+import { Card, CardContent } from "@/components/ui/card";
+import { Badge } from "@/components/ui/badge";
+import { Button } from "@/components/ui/button";
+import { ProviderIcon } from "@/components/ProviderIcon";
+import type { UniversalProvider } from "@/types";
+import { useAccountProfile } from "./useAccountProfile";
+import {
+  formatCurrency,
+  formatTokenCount,
+  maskKey,
+  usedPercent,
+  keyUsedPercent,
+  formatExpiry,
+  keyStatusLabel,
+} from "@/lib/account/format";
+
+interface KeyCardProps {
+  provider: UniversalProvider;
+  // 重新铺开到各 CLI（补丁 05 接线）。可选：未接线时按钮不渲染。
+  onImport?: (provider: UniversalProvider) => void;
+  importing?: boolean;
+}
+
+export function KeyCard({ provider, onImport, importing }: KeyCardProps) {
+  const { t } = useTranslation();
+  const { data, isFetching, isError, refetch } = useAccountProfile({
+    keyId: provider.id,
+    baseUrl: provider.baseUrl,
+    apiKey: provider.apiKey,
+  });
+
+  const profile = data?.ok ? data.profile : undefined;
+  // 展示名：本地 name 优先，空则用远端 token.Name，再空用占位。
+  const displayName =
+    provider.name.trim() ||
+    profile?.tokenName.trim() ||
+    t("account.unnamedKey", { defaultValue: "未命名 key" });
+
+  const errorText =
+    (data && !data.ok ? data.error : undefined) ??
+    (isError
+      ? t("account.loadError", { defaultValue: "加载失败，稍后重试" })
+      : undefined);
+
+  const expiry = profile ? formatExpiry(profile.keyExpiresAt) : null;
+  const statusLabel = profile ? keyStatusLabel(profile.keyStatus) : "";
+
+  return (
+    <Card>
+      <CardContent className="p-4 space-y-3">
+        {/* 头部：图标 + 名称 + 打码 key + 徽标 + 刷新 */}
+        <div className="flex items-start justify-between gap-3">
+          <div className="flex items-center gap-3 min-w-0">
+            <ProviderIcon
+              icon={provider.icon}
+              name={provider.name}
+              size={28}
+            />
+            <div className="min-w-0">
+              <div className="flex items-center gap-2">
+                <span className="font-medium truncate">{displayName}</span>
+                {statusLabel && (
+                  <Badge variant="destructive">{statusLabel}</Badge>
+                )}
+                {profile?.keyDynamicRatio && (
+                  <Badge variant="secondary">
+                    {t("account.dynamicRatio", { defaultValue: "动态倍率" })}
+                  </Badge>
+                )}
+                {expiry && expiry.level !== "ok" && (
+                  <Badge
+                    variant={
+                      expiry.level === "expired" ? "destructive" : "secondary"
+                    }
+                  >
+                    {expiry.text}
+                  </Badge>
+                )}
+              </div>
+              <span className="text-xs text-muted-foreground font-mono">
+                {maskKey(provider.apiKey)}
+              </span>
+            </div>
+          </div>
+          <Button
+            variant="ghost"
+            size="icon"
+            onClick={() => refetch()}
+            title={t("account.refresh", { defaultValue: "刷新" })}
+            disabled={isFetching}
+          >
+            <RefreshCw
+              className={`w-4 h-4 ${isFetching ? "animate-spin" : ""}`}
+            />
+          </Button>
+        </div>
+
+        {/* 错误态 */}
+        {errorText && (
+          <div className="text-xs text-destructive">{errorText}</div>
+        )}
+
+        {/* 就绪态：余额 + 用量指标 */}
+        {profile && (
+          <div className="grid grid-cols-2 gap-3 sm:grid-cols-4">
+            <Metric
+              label={t("account.accountBalance", { defaultValue: "账户余额" })}
+              value={formatCurrency(profile.accountRemainingQuota)}
+            />
+            <Metric
+              label={t("account.todayTokens", { defaultValue: "今日 Tokens" })}
+              value={formatTokenCount(profile.accountTokensUsedToday)}
+            />
+            <Metric
+              label={t("account.keyQuota", { defaultValue: "Key 额度" })}
+              value={
+                profile.keyUnlimitedQuota
+                  ? t("account.unlimited", { defaultValue: "不限" })
+                  : formatCurrency(profile.keyRemainingQuota)
+              }
+            />
+            <Metric
+              label={t("account.todayRequests", { defaultValue: "今日请求" })}
+              value={
+                profile.requestCountToday === null
+                  ? "—"
+                  : String(profile.requestCountToday)
+              }
+            />
+          </div>
+        )}
+
+        {/* 账户额度使用率条（unlimited 不展示） */}
+        {profile && !profile.keyUnlimitedQuota && (
+          <UsageBar
+            percent={
+              profile.accountTotalQuota > 0
+                ? usedPercent(
+                    profile.accountUsedQuota,
+                    profile.accountTotalQuota,
+                  )
+                : keyUsedPercent(
+                    profile.keyUsedQuota,
+                    profile.keyRemainingQuota,
+                  )
+            }
+          />
+        )}
+
+        {/* 重新铺开按钮 */}
+        {onImport && (
+          <div className="flex justify-end">
+            <Button
+              variant="outline"
+              size="sm"
+              onClick={() => onImport(provider)}
+              disabled={importing}
+            >
+              {importing
+                ? t("account.importing", { defaultValue: "铺开中…" })
+                : t("account.importToClis", {
+                    defaultValue: "重新铺开到各 CLI",
+                  })}
+            </Button>
+          </div>
+        )}
+      </CardContent>
+    </Card>
+  );
+}
+
+function Metric({ label, value }: { label: string; value: string }) {
+  return (
+    <div className="space-y-0.5">
+      <div className="text-xs text-muted-foreground">{label}</div>
+      <div className="text-sm font-semibold tabular-nums">{value}</div>
+    </div>
+  );
+}
+
+function UsageBar({ percent }: { percent: number }) {
+  return (
+    <div className="h-1.5 w-full rounded-full bg-muted overflow-hidden">
+      <div
+        className="h-full rounded-full bg-blue-500 transition-all"
+        style={{ width: `${percent}%` }}
+      />
+    </div>
+  );
+}
diff --git a/src/components/account/importKey.ts b/src/components/account/importKey.ts
new file mode 100644
index 00000000..2818b452
--- /dev/null
+++ b/src/components/account/importKey.ts
@@ -0,0 +1,66 @@
+// [ccs] 一键导入 / 铺开逻辑。
+//
+// cc-switch 里「一个 new-api key」= 一条 providerType:"newapi" 的 UniversalProvider，
+// upsert 后 sync 会把该 {baseUrl, apiKey} + 预设模型一次性写进 Claude / Codex / Gemini 三个 CLI。
+// 这里封装两条路径：
+//   - bindAccount：账户面板表单「绑定新账户」——用 NewAPI 预设新建一条渠道，upsert + sync；
+//   - reapplyProvider：KeyCard「重新铺开到各 CLI」——已有渠道重新 sync（凭据/模型没变，仅重写 CLI 配置）。
+//
+// 与 open-code 对齐：open-code 那边「激活 key」= 把选中 key 写进各 CLI 的 env；这里等价动作是
+// upsert + sync（sync 即 cc-switch 的落盘到各应用配置）。
+
+import { universalProvidersApi } from "@/lib/api";
+import {
+  createUniversalProviderFromPreset,
+  findPresetByType,
+} from "@/config/universalProviderPresets";
+import { generateUUID } from "@/utils/uuid";
+import type { UniversalProvider } from "@/types";
+
+// [ccs] 规整 baseUrl：去掉尾部斜杠。后端 derive_api_base 会再做 /api/... 拼接，这里只做表层清理。
+function normalizeBaseUrl(raw: string): string {
+  return raw.trim().replace(/\/+$/, "");
+}
+
+export interface BindAccountArgs {
+  baseUrl: string;
+  apiKey: string;
+  // 展示名。留空则回落到预设名 "NewAPI"（远端 token.Name 由卡片按需覆盖展示）。
+  name?: string;
+}
+
+// [ccs] 绑定新账户：用 NewAPI 预设组装一条 newapi 渠道并落盘到各 CLI。返回新建的渠道。
+// 失败（找不到预设 / upsert 失败）抛错，由调用方（AccountPanel）捕获展示。
+export async function bindAccount({
+  baseUrl,
+  apiKey,
+  name,
+}: BindAccountArgs): Promise<UniversalProvider> {
+  const preset = findPresetByType("newapi");
+  if (!preset) {
+    throw new Error("缺少 NewAPI 预设，无法绑定账户");
+  }
+
+  const provider = createUniversalProviderFromPreset(
+    preset,
+    generateUUID(),
+    normalizeBaseUrl(baseUrl),
+    apiKey.trim(),
+    name?.trim() || undefined,
+  );
+
+  const ok = await universalProvidersApi.upsert(provider);
+  if (!ok) {
+    throw new Error("保存渠道失败");
+  }
+  // 铺开到 Claude / Codex / Gemini。sync 失败不影响渠道已存在，交由调用方决定是否提示。
+  await universalProvidersApi.sync(provider.id);
+  return provider;
+}
+
+// [ccs] 重新铺开已有渠道到各 CLI：凭据/模型未变，仅重写 CLI 配置（等价 open-code 的重新激活）。
+export async function reapplyProvider(
+  provider: UniversalProvider,
+): Promise<void> {
+  await universalProvidersApi.sync(provider.id);
+}
