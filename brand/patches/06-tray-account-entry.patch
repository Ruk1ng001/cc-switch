+  // [ccs] 监听托盘「我的账户」事件：托盘点击后 Rust 侧已弹出主窗口并 emit，此处打开账户面板。
+  useEffect(() => {
+    let unlisten: (() => void) | undefined;
+    let active = true;
+    void (async () => {
+      const { listen } = await import("@tauri-apps/api/event");
+      const un = await listen("ccs-open-account", () => {
+        setAccountPanelOpen(true);
+      });
+      if (active) {
+        unlisten = un;
+      } else {
+        un();
+      }
+    })();
+    return () => {
+      active = false;
+      unlisten?.();
+    };
+  }, []);
