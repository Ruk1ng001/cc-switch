 /// <reference types="vite/client" />
 
+// [ccs] 内置渠道的构建期注入变量。密钥/私有 baseURL 绝不写入仓库——
+// 仅由 CI 在打包时经这些 VITE_* env 注入（对齐 open-code 的 {env:NEWAPI_*} 模式）。
+// 三者留空时不 seed 任何内置渠道（见 lib/account/seedBuiltinChannel.ts）。
+interface ImportMetaEnv {
+  readonly VITE_NEWAPI_BASE_URL?: string;
+  readonly VITE_NEWAPI_API_KEY?: string;
+  readonly VITE_NEWAPI_CHANNEL_NAME?: string;
+}
+
+interface ImportMeta {
+  readonly env: ImportMetaEnv;
+}
+
 export {};
