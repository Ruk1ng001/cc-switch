+++ b/src/lib/account/seedBuiltinChannel.ts
@@ -0,0 +1,62 @@
+// [ccs] 内置渠道注入。
+//
+// 与 open-code 的内置渠道对齐：那边打包期用 {env:NEWAPI_*} 把渠道凭据注入 opencode.template.json；
+// 这里等价做法是构建期经 Vite env（VITE_NEWAPI_*）注入，首次启动 seed 一条 providerType:"newapi"
+// 的 UniversalProvider 并铺开到各 CLI（走 04 的 bindAccount → upsert + sync）。
+//
+// 安全：密钥绝不入仓（本文件只读 import.meta.env，值由 CI 在构建期注入最终包）。占位/本地开发
+//       （未配置或 example.com）时直接 no-op。
+//
+// 幂等 + 只注入一次：localStorage 标志确保用户显式删除后不复活；同 baseUrl 已存在则只置标志不重复建。
+
+import { universalProvidersApi } from "@/lib/api";
+import { bindAccount } from "@/components/account/importKey";
+
+// [ccs] 标志键：已 seed 过内置渠道。置位后即使用户删掉渠道也不再自动注入。
+const SEED_FLAG = "ccs.builtinChannelSeeded";
+
+function readEnv(key: string): string {
+  const v = (import.meta.env as Record<string, string | undefined>)[key];
+  return typeof v === "string" ? v.trim() : "";
+}
+
+function stripTrailingSlash(u: string): string {
+  return u.replace(/\/+$/, "");
+}
+
+// [ccs] 首次启动注入内置渠道。失败不抛（不阻塞启动），未置标志时下次启动重试。
+export async function seedBuiltinChannel(): Promise<void> {
+  const baseUrl = readEnv("VITE_NEWAPI_BASE_URL");
+  const apiKey = readEnv("VITE_NEWAPI_API_KEY");
+  const name = readEnv("VITE_NEWAPI_CHANNEL_NAME") || "内置渠道";
+
+  // 未配置构建期凭据（占位 / 本地开发）→ 不注入。
+  if (!baseUrl || !apiKey) return;
+  // 占位样例值防呆：example.com 视为未配置。
+  if (baseUrl.includes("example.com")) return;
+
+  // 只 seed 一次：用户显式删除后不应复活。
+  try {
+    if (localStorage.getItem(SEED_FLAG)) return;
+  } catch {
+    // localStorage 不可用时保守跳过（避免重复注入）。
+    return;
+  }
+
+  try {
+    // 幂等：已存在同 baseUrl 的 newapi 渠道则只置标志，不重复建。
+    const existing = await universalProvidersApi.getAll();
+    const dup = Object.values(existing).some(
+      (p) =>
+        p.providerType === "newapi" &&
+        stripTrailingSlash(p.baseUrl) === stripTrailingSlash(baseUrl),
+    );
+    if (!dup) {
+      await bindAccount({ baseUrl, apiKey, name });
+    }
+    localStorage.setItem(SEED_FLAG, String(Date.now()));
+  } catch (e) {
+    // 注入失败不阻塞启动；未置标志，下次启动重试。
+    console.error("[ccs] 内置渠道注入失败", e);
+  }
+}
